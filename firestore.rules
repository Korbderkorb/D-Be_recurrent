rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (required, 'admin' or 'student')
    //   - avatar: string (optional)
    //   - allowedTopics: list (optional)
    //   - hasCompletedTour: boolean (optional)
    //   - hasCompletedTopicTour: boolean (optional)
    //   - stats: map (optional)
    //
    // Collection: progress
    // Document ID: {userId}
    // Fields:
    //   - completedSubTopics: list (required)
    //   - submittedExercises: list (required)
    //
    // Collection: submissions
    // Document ID: {submissionId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - subTopicId: string (required)
    //   - topicId: string (required)
    //   - timestamp: string (required)
    //   - files: list (required)
    //   - status: string (required, 'pending', 'reviewed', 'rejected')
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - topicId: string (required)
    //   - subTopicId: string (required)
    //   - topicTitle: string (required)
    //   - subTopicTitle: string (required)
    //   - submissionId: string (required)
    //   - timestamp: string (required)
    //   - read: boolean (required)
    //   - type: string (required, 'EXERCISE_SUBMISSION')
    //   - files: list (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isBootstrapAdmin() {
      return isAuthenticated() && request.auth.token.email == "korbinian.enzinger@gmail.com";
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         isBootstrapAdmin());
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role']) &&
             data.email is string && data.email.size() < 200 &&
             data.name is string && data.name.size() < 100 &&
             data.role in ['admin', 'student'] &&
             (!('status' in data) || data.status in ['pending', 'active']) &&
             (!('hasCompletedTour' in data) || data.hasCompletedTour is bool) &&
             (!('hasCompletedTopicTour' in data) || data.hasCompletedTopicTour is bool);
    }

    function isValidProgress(data) {
      return data.completedSubTopics is list && data.completedSubTopics.size() < 1000 &&
             data.submittedExercises is list && data.submittedExercises.size() < 1000 &&
             (!('quizAttempts' in data) || (data.quizAttempts is list && data.quizAttempts.size() < 500));
    }

    function isValidComment(comment) {
      return comment.keys().hasAll(['id', 'user', 'avatar', 'text', 'timestamp', 'reactions', 'replies']) &&
             comment.id is string &&
             comment.user is string && comment.user.size() < 100 &&
             comment.avatar is string &&
             comment.text is string && comment.text.size() < 2000 &&
             comment.timestamp is string &&
             comment.reactions is map &&
             comment.replies is list;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'subTopicId', 'topicId', 'files', 'timestamp', 'status']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.subTopicId is string &&
             data.topicId is string &&
             data.timestamp is string &&
             data.files is list && data.files.size() <= 10 &&
             data.status in ['pending', 'reviewed', 'rejected'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'topicId', 'subTopicId', 'topicTitle', 'subTopicTitle', 'submissionId', 'timestamp', 'read', 'type', 'files']) &&
             data.userId == request.auth.uid &&
             data.read == false &&
             data.type == 'EXERCISE_SUBMISSION';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow read if:
      // 1. Authenticated and reading own UID doc
      // 2. Authenticated and reading own Email doc (for claiming)
      // 3. Admin reading anything
      allow read: if isAuthenticated() && (
        userId == request.auth.uid || 
        userId == request.auth.token.email ||
        isAdmin()
      );
      
      // Allow create if:
      // 1. Admin is creating it (for invitations)
      // 2. User is creating their own UID doc AND they have a pending invitation
      //    CRITICAL: Must match the role they were invited with to prevent escalation
      allow create: if isAdmin() || (
        isOwner(userId) && 
        exists(/databases/$(database)/documents/users/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.status == 'pending' &&
        request.resource.data.role == get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role
      );
      
      // Allow update if:
      // 1. Owner or Admin
      //    CRITICAL: Only bootstrap admin can change roles
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isBootstrapAdmin());
      
      // Allow delete if:
      // 1. Admin
      // 2. User is deleting their own PENDING doc (email as ID) after claiming it
      allow delete: if isAdmin() || (
        isAuthenticated() && 
        userId == request.auth.token.email && 
        resource.data.status == 'pending'
      );
    }

    match /admin_only/check {
      allow read: if isAdmin();
    }

    match /progress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && isValidProgress(request.resource.data);
    }

    match /comments/{subTopicId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                    request.resource.data.comments is list && 
                    request.resource.data.comments.size() < 500 &&
                    (request.resource.data.comments.size() == 0 || isValidComment(request.resource.data.comments[0]));
    }

    match /topics/{topicId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config/landing {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
