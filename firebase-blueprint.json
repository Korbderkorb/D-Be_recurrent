{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and progress data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "status": { "type": "string", "enum": ["pending", "active"] },
        "profileColor": { "type": "string", "description": "Custom color for the user's avatar and graphs" },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "User's preferred theme" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "List of tag names assigned to the user" },
        "allowedTopics": { "type": "array", "items": { "type": "string" } },
        "hasCompletedTour": { "type": "boolean", "description": "Whether the user has finished the onboarding tutorial" },
        "hasCompletedTopicTour": { "type": "boolean", "description": "Whether the user has finished the topic detail tutorial" },
        "stats": {
          "type": "object",
          "properties": {
            "modulesCompleted": { "type": "number" },
            "totalModules": { "type": "number" },
            "lastActive": { "type": "string" }
          }
        }
      },
      "required": ["email", "name", "role"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User progress tracking for subtopics",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "completedSubTopics": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "completedAt": { "type": "string" }
            }
          } 
        },
        "submittedExercises": { "type": "array", "items": { "type": "string" } },
        "quizAttempts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subTopicId": { "type": "string" },
              "timestamp": { "type": "string" },
              "score": { "type": "number" },
              "total": { "type": "number" },
              "passed": { "type": "boolean" },
              "timeTaken": { "type": "number" },
              "wrongAnswers": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "required": ["userId"]
    },
    "Topic": {
      "title": "Topic",
      "description": "Curriculum topic with subtopics",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "imageUrl": { "type": "string" },
        "color": { "type": "string" },
        "level": { "type": "number" },
        "subTopics": { "type": "array", "items": { "type": "object" } },
        "relatedTopics": { "type": "array", "items": { "type": "string" } },
        "teacher": { "$ref": "Teacher" }
      },
      "required": ["id", "title", "subTopics"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Teacher profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" }
      },
      "required": ["id", "name", "email"]
    },
    "LandingConfig": {
      "title": "LandingConfig",
      "description": "Configuration for the landing page content",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "tag": { "type": "string" },
        "heroImage": { "type": "string" },
        "heroImageLight": { "type": "string" },
        "heroImageDark": { "type": "string" },
        "appLogoUrlLight": { "type": "string" },
        "appLogoUrlDark": { "type": "string" },
        "faviconUrlLight": { "type": "string" },
        "faviconUrlDark": { "type": "string" },
        "description": { "type": "string" },
        "quote": { "type": "string" }
      },
      "required": ["title", "subtitle", "tag", "heroImage", "description", "quote"]
    },
    "Tag": {
      "title": "Tag",
      "description": "User group tag with color and description",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "color"]
    },
    "ExerciseSubmission": {
      "title": "ExerciseSubmission",
      "description": "Metadata for a student's exercise submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "subTopicId": { "type": "string" },
        "topicId": { "type": "string" },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "size": { "type": "number" },
              "type": { "type": "string" },
              "requirementLabel": { "type": "string" }
            }
          }
        },
        "timestamp": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "rejected"] },
        "feedback": { "type": "string" },
        "grade": { "type": "number" }
      },
      "required": ["id", "userId", "userName", "subTopicId", "topicId", "files", "timestamp", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for users and admins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The user who this notification is FOR" },
        "userName": { "type": "string", "description": "The user who triggered the notification" },
        "topicId": { "type": "string" },
        "subTopicId": { "type": "string" },
        "topicTitle": { "type": "string" },
        "subTopicTitle": { "type": "string" },
        "submissionId": { "type": "string" },
        "timestamp": { "type": "string" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["EXERCISE_SUBMISSION", "SUBMISSION_COMMENT", "DEADLINE_WARNING"] },
        "files": { "type": "array", "items": { "type": "object" } },
        "evaluated": { "type": "boolean" },
        "grade": { "type": "number" },
        "feedback": { "type": "string" },
        "completed": { "type": "boolean" },
        "hasNewComments": { "type": "boolean" },
        "lastCommentTimestamp": { "type": "string" },
        "targetUserId": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "topicId", "subTopicId", "topicTitle", "subTopicTitle", "timestamp", "read", "type"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment or reply",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user": { "type": "string" },
        "avatar": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "reactions": { "type": "object", "description": "Map of emoji to array of user IDs" },
        "replies": { "type": "array", "items": { "$ref": "Comment" } }
      },
      "required": ["id", "user", "avatar", "text", "timestamp", "reactions", "replies"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "tags/{tagId}": {
      "schema": "Tag",
      "description": "User group tag documents"
    },
    "progress/{userId}": {
      "schema": "Progress",
      "description": "User progress documents"
    },
    "topics/{topicId}": {
      "schema": "Topic",
      "description": "Curriculum topic documents"
    },
    "teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Teacher profile documents"
    },
    "comments/{subTopicId}": {
      "schema": {
        "type": "object",
        "properties": {
          "comments": { "type": "array", "items": { "$ref": "Comment" } }
        }
      },
      "description": "Comments for a specific subtopic"
    },
    "quizAttempts/{userId}": {
      "schema": "object",
      "description": "Quiz attempts for a user"
    },
    "admin_only/check": {
      "schema": "object",
      "description": "Canary document for admin status verification"
    },
    "config/landing": {
      "schema": "LandingConfig",
      "description": "Global landing page configuration"
    },
    "submissions/{submissionId}": {
      "schema": "ExerciseSubmission",
      "description": "Student exercise submission documents"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Admin notifications"
    }
  }
}
